{
  "name": "@mcpapps/dev",
  "version": "0.0.0",
  "description": "Local host emulator, dev server and Cloudflare tunnel for MCP Apps.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@mcpapps/protocol": "workspace:*",
    "@mcpapps/server": "workspace:*",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "author": "Rubens Peculis",
  "homepage": "https://github.com/rubenspeculis/mcp-apps#readme",
  "bugs": "https://github.com/rubenspeculis/mcp-apps/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubenspeculis/mcp-apps.git",
    "directory": "packages/dev"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-apps",
    "mcp-ui",
    "hono",
    "ai"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
