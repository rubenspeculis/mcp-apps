{
  "name": "@mcpapps/cli",
  "version": "0.1.2",
  "description": "Scaffold and run MCP Apps: create-mcpapp + the mcpapps CLI.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "mcpapps": "./bin/mcpapps.mjs",
    "create-mcpapp": "./bin/create-mcpapp.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "jiti": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "playwright": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "author": "Rubens Peculis",
  "homepage": "https://github.com/rubenspeculis/mcp-apps#readme",
  "bugs": "https://github.com/rubenspeculis/mcp-apps/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubenspeculis/mcp-apps.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-apps",
    "mcp-ui",
    "hono",
    "ai"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
