{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "weather-flutter",
  "main": "src/worker.ts",
  "compatibility_date": "2025-09-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    // Pre-built Flutter web files, written by src/pre-deploy.ts
    "directory": "dist"
  }
}
