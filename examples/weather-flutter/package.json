    "zod": "catalog:"
  },
  "devDependencies": {
    "@mcpapps/cli": "workspace:*",
    "@mcpapps/dev": "workspace:*",
    "@mcpapps/typegen": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "catalog:",
