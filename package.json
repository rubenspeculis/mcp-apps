{
  "name": "mcpapps-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "pnpm install && pnpm codegen",
    "dev": "turbo dev --filter=!@mcpapps/docs",
    "dev:vue": "pnpm --filter @mcpapps/example-weather-vue dev",
    "dev:flutter": "pnpm --filter @mcpapps/example-weather-flutter start",
    "docs:dev": "pnpm --filter @mcpapps/docs dev",
    "docs:build": "pnpm --filter @mcpapps/docs build",
    "docs:deploy": "pnpm --filter @mcpapps/docs deploy",
    "scaffold": "pnpm --filter @mcpapps/cli build && node packages/cli/dist/create-bin.js",
    "build": "turbo build --filter=!@mcpapps/docs",
    "test": "turbo test && pnpm test:flutter-bridge",
    "coverage": "turbo test -- --coverage",
    "test:flutter-bridge": "cd packages/flutter_bridge && fvm flutter test",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "turbo typecheck",
    "check": "biome ci . && turbo typecheck test",
    "codegen": "turbo codegen",
    "clean": "turbo clean && rm -rf .turbo",
    "clean:full": "pnpm clean && rm -rf node_modules **/node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "ship": "pnpm check && turbo build && pnpm -r publish --access public --no-git-checks",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "lefthook": "catalog:",
    "tsup": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:"
  }
}
